{
  "name": "zap402-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Zap402 — pay-per-query AI agent marketplace on Stellar",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:vite\"",
    "dev:vite": "vite",
    "dev:api": "node server/dev-api.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klarqqs/zap402.git"
  },
  "prettier": "@stellar/prettier-config",
  "keywords": [],
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stellar/prettier-config": "^1.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "busboy": "^1.6.0",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.7",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^2.8.8",
    "sass": "^1.62.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.3.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vite-plugin-svgr": "^5.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.9.5",
    "@emotion/is-prop-valid": "^1.4.0",
    "@stellar/freighter-api": "1.7.1",
    "@stellar/stellar-sdk": "^14.6.1",
    "bignumber.js": "^9.1.1",
    "framer-motion": "^12.23.24",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.553.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.5",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  }
}
