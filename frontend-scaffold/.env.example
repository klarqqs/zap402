# Copy to `.env` in this folder. Vite only exposes `VITE_*` vars; restart `npm run dev` after changes.
# Contract deploy + `VITE_CONTRACT_ID`: repo root README → “Build & deploy contract (testnet)”.

# Optional (defaults to testnet Soroban RPC if unset)
# VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed Soroban contract ID (starts with C). Leave empty to disable on-chain features.
# For USDC tips aligned with unlocks: deploy + initialize with testnet USDC SAC (see ./scripts/deploy-testnet.sh).
VITE_CONTRACT_ID=

# TESTNET | FUTURENET | MAINNET
VITE_NETWORK=TESTNET

# Optional: classic G-address that exists on this network (funded). Used only as Soroban simulate tx source for read-only get_profile — not your wallet.
# VITE_READONLY_SIM_ACCOUNT=

# Optional: override USDC Stellar Asset Contract for unlocks (any network).
# If unset on TESTNET, the app uses public testnet USDC (Circle) automatically.
# On mainnet (wallet PUBLIC), you must set this to real USDC’s contract id.
# VITE_USDC_CONTRACT_ID=

# Optional: ImgBB API key for profile photo upload in Edit profile / registration (https://api.imgbb.com/).
# Without it, users can still paste a direct https image URL (max 256 characters on-chain).
# VITE_IMGBB_API_KEY=
