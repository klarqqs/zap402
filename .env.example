# Anthropic (Clone / “Ask” feature). Never commit real keys.
# Copy to `.env` at the repository root (same folder as this file’s parent).
ANTHROPIC_API_KEY=

# Optional: defaults to claude-3-5-haiku-20241022
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional: local Clone API port (default 8788). Vite proxies /api → here.
# CLONE_API_PORT=8788

# Unlock module: dev API verifies Stellar txs on Horizon (set to match your network).
# HORIZON_URL=https://horizon-testnet.stellar.org

# Optional: override USDC Stellar Asset Contract for unlocks. Testnet defaults automatically if unset.
# VITE_USDC_CONTRACT_ID=
